generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id
  workspaceId  String
  name         String
  email        String     @unique
  passwordHash String
  role         String
  createdAt    DateTime
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]
  appSessions  AppSession[]
  gmailOAuthStates GmailOAuthState[]

  @@index([workspaceId])
  @@map("users")
}

model Workspace {
  id            String           @id
  name          String
  ownerId       String
  plan          String
  createdAt     DateTime
  settings      Json?
  users         User[]
  gmailAccounts GmailAccount[]
  gmailOAuthStates GmailOAuthState[]
  emails        EmailMessage[]
  alerts        Alert[]
  senders       SenderProfile[]
  rules         AutomationRule[]
  auditLogs     AuditLog[]
  syncLogs      GmailSyncLog[]
  appSessions   AppSession[]

  @@map("workspaces")
}

model GmailOAuthState {
  id          String    @id
  workspaceId String
  userId      String
  accountId   String?
  nonce       String
  stateHash   String    @unique
  createdAt   DateTime
  expiresAt   DateTime
  consumedAt  DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, expiresAt])
  @@index([userId, consumedAt])
  @@map("gmail_oauth_states")
}

model AppSession {
  id         String    @id
  workspaceId String
  userId     String
  role       String
  createdAt  DateTime
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  ip         String?
  userAgent  String?
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([workspaceId])
  @@map("app_sessions")
}

model GmailAccount {
  id              String           @id
  workspaceId     String
  emailAddress    String
  status          String
  lastSyncAt      DateTime?
  watchExpiration DateTime?
  totalMessages   Int
  grantedScopes   Json
  errorMessage    String?
  historyId       String?
  createdAt       DateTime
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  oauthToken      GmailOAuthToken?
  emails          EmailMessage[]
  alerts          Alert[]
  syncLogs        GmailSyncLog[]

  @@unique([workspaceId, emailAddress])
  @@index([workspaceId])
  @@map("gmail_accounts")
}

model GmailOAuthToken {
  gmailAccountId        String       @id
  workspaceId           String
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  encryptedIdToken      String?
  scope                 String?
  tokenType             String?
  expiryDate            BigInt?
  createdAt             DateTime
  updatedAt             DateTime
  gmailAccount          GmailAccount @relation(fields: [gmailAccountId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("gmail_oauth_tokens")
}

model GmailSyncLog {
  id              String       @id
  workspaceId     String
  gmailAccountId  String
  status          String
  startedAt       DateTime
  finishedAt      DateTime?
  fetchedMessages Int
  createdMessages Int
  updatedMessages Int
  errorMessage    String?
  metadata        Json
  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  gmailAccount    GmailAccount @relation(fields: [gmailAccountId], references: [id], onDelete: Cascade)

  @@index([workspaceId, gmailAccountId, startedAt])
  @@index([workspaceId, status])
  @@map("gmail_sync_logs")
}

model EmailMessage {
  id             String       @id
  workspaceId    String
  gmailAccountId String
  gmailMessageId String
  threadId       String
  accountEmail   String
  fromEmail      String
  fromName       String?
  fromDomain     String
  toEmails       Json
  subject        String
  snippet        String
  bodyHtml       String?
  bodyText       String?
  receivedAt     DateTime
  labelIds       Json
  hasAttachments Boolean
  attachments    Json
  isRead         Boolean
  isSpam         Boolean
  isImportant    Boolean
  reviewedAt     DateTime?
  gmailUrl       String?
  classification Json?
  classificationPrimaryCategory String?
  classificationCategoryTags String[] @default([])
  classificationImportanceScore Int?
  classificationSpamScore Int?
  classificationRiskScore Int?
  classificationSecurityScore Int?
  classificationActionRequired Boolean?
  actionHistory  Json
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  gmailAccount   GmailAccount @relation(fields: [gmailAccountId], references: [id], onDelete: Cascade)
  alerts         Alert[]

  @@unique([workspaceId, gmailAccountId, gmailMessageId])
  @@index([workspaceId, receivedAt])
  @@index([workspaceId, fromEmail])
  @@index([workspaceId, fromDomain])
  @@index([workspaceId, classificationPrimaryCategory])
  @@index([workspaceId, classificationImportanceScore])
  @@index([workspaceId, classificationRiskScore])
  @@index([workspaceId, classificationSecurityScore])
  @@index([gmailAccountId])
  @@map("email_messages")
}

model Alert {
  id                String        @id
  workspaceId       String
  gmailAccountId    String
  emailMessageId    String?
  type              String
  severity          String
  title             String
  description       String
  status            String
  recommendedAction String
  createdAt         DateTime
  resolvedAt        DateTime?
  workspace         Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  gmailAccount      GmailAccount  @relation(fields: [gmailAccountId], references: [id], onDelete: Cascade)
  emailMessage      EmailMessage? @relation(fields: [emailMessageId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([workspaceId, severity])
  @@map("alerts")
}

model SenderProfile {
  id            String    @id
  workspaceId   String
  email         String
  domain        String
  displayName   String?
  totalMessages Int
  lastSeenAt    DateTime
  trustScore    Int
  riskScore     Int
  category      String?
  status        String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId, domain])
  @@map("sender_profiles")
}

model AutomationRule {
  id           String    @id
  workspaceId  String
  name         String
  description  String?
  conditions   Json
  actions      Json
  priority     Int
  enabled      Boolean
  timesApplied Int
  createdAt    DateTime
  updatedAt    DateTime
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, enabled])
  @@index([workspaceId, priority])
  @@map("automation_rules")
}

model AuditLog {
  id          String    @id
  workspaceId String
  userId      String?
  action      String
  entityType  String
  entityId    String?
  description String
  ip          String?
  metadata    Json
  createdAt   DateTime
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, action])
  @@map("audit_logs")
}
